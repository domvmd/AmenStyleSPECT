         </widget>
        </item>
        <item row="1" column="2">
         <widget class="QPushButton" name="viewRightButton">
          <property name="text">
           <string>Right</string>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout" name="outputDirLayout">
        <item>
         <widget class="QLabel" name="outputDirLabel">
          <property name="text">
           <string>Output folder:</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="ctkDirectoryButton" name="outputDirButton"/>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout" name="exportLayout">
        <item>
         <widget class="QPushButton" name="exportSurfaceButton">
          <property name="text">
           <string>Export Surface 6-view PNG</string>
          </property>
          <property name="toolTip">
           <string>Regenerate the surface scan and save 6 view PNGs + montage.png to &lt;output folder&gt;/surface_views/.</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="exportActiveButton">
          <property name="text">
           <string>Export Active 6-view PNG</string>
          </property>
          <property name="toolTip">
           <string>Regenerate the active scan and save 6 view PNGs + montage.png to &lt;output folder&gt;/active_views/.</string>
          </property>
         </widget>
        </item>
       </layout>
      </item>
     </layout>
    </widget>
   </item>
   <!-- ================= REGIONAL QUANTIFICATION ================= -->
   <item>
    <widget class="ctkCollapsibleButton" name="regionsCollapsibleButton">
     <property name="text">
      <string>Regional quantification (hypo / hyper vs cerebellar max)</string>
     </property>
     <layout class="QVBoxLayout" name="regionsLayout">
      <item>
       <widget class="QLabel" name="regionsNoteLabel">
        <property name="text">
         <string>One named Box ROI per region; each region's uptake is read as a % of the cerebellar reference and classified hypo (&lt;60%) / normal / hyper (&gt;80%). "Create 53-region scaffold" drops approximate boxes you then drag onto each structure - confirm orientation first.</string>
        </property>
        <property name="wordWrap">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <layout class="QFormLayout" name="regionsFormLayout">
        <item row="0" column="0">
         <widget class="QLabel" name="regionMetricLabel">
          <property name="text">
           <string>Region metric:</string>
          </property>
         </widget>
        </item>
        <item row="0" column="1">
         <widget class="QComboBox" name="regionMetricComboBox">
          <property name="toolTip">
           <string>Mean = region average uptake; Peak = region's hottest voxel.</string>
          </property>
         </widget>
        </item>
        <item row="1" column="0">
         <widget class="QLabel" name="regionRefModeLabel">
          <property name="text">
           <string>Reference (denominator):</string>
          </property>
         </widget>
        </item>
        <item row="1" column="1">
         <widget class="QComboBox" name="regionRefModeComboBox">
          <property name="toolTip">
           <string>% of cerebellar MAX uses the accepted Maximum Cerebellar Count. % of cerebellar-region MEAN uses the mean inside the cerebellum ROI.</string>
          </property>
         </widget>
        </item>
        <item row="2" column="0">
         <widget class="QLabel" name="hypoPctLabel">
          <property name="text">
           <string>Hypoactive below (% of ref):</string>
          </property>
         </widget>
        </item>
        <item row="2" column="1">
         <widget class="QDoubleSpinBox" name="hypoPctSpinBox">
          <property name="decimals">
           <number>0</number>
          </property>
          <property name="minimum">
           <double>10.0</double>
          </property>
          <property name="maximum">
           <double>100.0</double>
          </property>
          <property name="singleStep">
           <double>1.0</double>
          </property>
          <property name="value">
           <double>55.0</double>
          </property>
         </widget>
        </item>
        <item row="3" column="0">
         <widget class="QLabel" name="hyperPctLabel">
          <property name="text">
           <string>Hyperactive above (% of ref):</string>
          </property>
         </widget>
        </item>
        <item row="3" column="1">
         <widget class="QDoubleSpinBox" name="hyperPctSpinBox">
          <property name="decimals">
           <number>0</number>
          </property>
          <property name="minimum">
           <double>50.0</double>
          </property>
          <property name="maximum">
           <double>200.0</double>
          </property>
          <property name="singleStep">
           <double>1.0</double>
          </property>
          <property name="value">
           <double>85.0</double>
          </property>
         </widget>
        </item>
        <item row="4" column="0">
         <widget class="QLabel" name="regionFloorLabel">
          <property name="text">
           <string>Tissue floor (% of cereb. max):</string>
          </property>
         </widget>
        </item>
        <item row="4" column="1">
         <widget class="QDoubleSpinBox" name="regionFloorSpinBox">
          <property name="decimals">
           <number>1</number>
          </property>
          <property name="minimum">
           <double>0.0</double>
          </property>
          <property name="maximum">
           <double>30.0</double>
          </property>
          <property name="singleStep">
           <double>1.0</double>
          </property>
          <property name="value">
           <double>5.0</double>
          </property>
          <property name="toolTip">
           <string>Voxels below this % of the cerebellar max are treated as CSF/background and excluded from the region mean.</string>
          </property>
         </widget>
        </item>
        <item row="5" column="0">
         <widget class="QLabel" name="asymmetryPctLabel">
          <property name="text">
           <string>Flag L/R asymmetry above (%):</string>
          </property>
         </widget>
        </item>
        <item row="5" column="1">
         <widget class="QDoubleSpinBox" name="asymmetryPctSpinBox">
          <property name="decimals">
           <number>0</number>
          </property>
          <property name="minimum">
           <double>0.0</double>
          </property>
          <property name="maximum">
           <double>100.0</double>
          </property>
          <property name="singleStep">
           <double>1.0</double>
          </property>
          <property name="value">
           <double>15.0</double>
          </property>
         </widget>
        </item>
        <item row="6" column="0">
         <widget class="QLabel" name="focalHyperLabel">
          <property name="text">
           <string>Focal hyperactivity:</string>
          </property>
         </widget>
        </item>
        <item row="6" column="1">
         <widget class="QCheckBox" name="focalHyperCheckBox">
          <property name="text">
           <string>flag from hot voxels, not the mean</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
          <property name="toolTip">
           <string>A region is hyperactive if a focal cluster of its voxels exceeds the hyper %, even when the surrounding tissue drags the ROI mean down to "normal". Mirrors masking at the hyper threshold and averaging inside the mask.</string>
          </property>
         </widget>
        </item>
        <item row="7" column="0">
         <widget class="QLabel" name="minHotVoxelsLabel">
          <property name="text">
           <string>Focal: min hot voxels:</string>
          </property>
         </widget>
        </item>
        <item row="7" column="1">
         <widget class="QSpinBox" name="minHotVoxelsSpinBox">
          <property name="minimum">
           <number>1</number>
          </property>
          <property name="maximum">
           <number>100000</number>
          </property>
          <property name="singleStep">
           <number>1</number>
          </property>
          <property name="value">
           <number>3</number>
          </property>
          <property name="toolTip">
           <string>Hyperactive if the ROI holds at least this many hot voxels (>= hyper %). This is the intuitive dial - the "Hot %" column shows each region's hot-voxel count in parentheses. Raise it if noise over-flags; lower it (min 1) for the smallest foci.</string>
          </property>
         </widget>
        </item>
        <item row="8" column="0">
         <widget class="QLabel" name="minHotFracLabel">
          <property name="text">
           <string>Focal: or min hot fraction (%):</string>
          </property>
         </widget>
        </item>
        <item row="8" column="1">
         <widget class="QDoubleSpinBox" name="minHotFracSpinBox">
          <property name="decimals">
           <number>0</number>
          </property>
          <property name="minimum">
           <double>1.0</double>
          </property>
          <property name="maximum">
           <double>100.0</double>
          </property>
          <property name="singleStep">
           <double>1.0</double>
          </property>
          <property name="value">
           <double>5.0</double>
          </property>
          <property name="toolTip">
           <string>Alternative trigger: hyperactive if at least this % of the ROI is hot. OR'd with the hot-voxel count, so either one flags the region. Default 5% so small-but-real foci visible on the active render also flag in the table.</string>
          </property>
         </widget>
        </item>
        <item row="9" column="0">
         <widget class="QLabel" name="focalHypoLabel">
          <property name="text">
           <string>Focal hypoactivity:</string>
          </property>
         </widget>
        </item>
        <item row="9" column="1">
         <widget class="QCheckBox" name="focalHypoCheckBox">
          <property name="text">
           <string>flag dents from low voxels, not the mean</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
          <property name="toolTip">
           <string>A region is hypoactive if a focal cluster of its voxels falls BELOW the hypo % (the same cut the 3D surface uses to carve a hole), even when the parcel mean clears the hypo line. Makes the table agree with the surface holes. A region with both a dent and a hot focus is "Mixed".</string>
          </property>
         </widget>
        </item>
        <item row="10" column="0">
         <widget class="QLabel" name="minLowFracLabel">
          <property name="text">
           <string>Focal: min low fraction (%):</string>
          </property>
         </widget>
        </item>
        <item row="10" column="1">
         <widget class="QDoubleSpinBox" name="minLowFracSpinBox">
          <property name="decimals">
           <number>0</number>
          </property>
          <property name="minimum">
           <double>1.0</double>
          </property>
          <property name="maximum">
           <double>100.0</double>
          </property>
          <property name="singleStep">
           <double>1.0</double>
          </property>
          <property name="value">
           <double>40.0</double>
          </property>
          <property name="toolTip">
           <string>Hypoactive if at least this % of the region's voxels fall below the hypo % (the surface-hole cut). The "Low %" column shows each region's count. On a globally dim scan raise it (the whole brain runs low); for isolated holes on an otherwise normal brain the default 40% is specific.</string>
          </property>
         </widget>
        </item>
        <item row="11" column="0">
         <widget class="QLabel" name="gradeStepLabel">
          <property name="text">
           <string>Grade step (% per color):</string>
          </property>
         </widget>
        </item>
        <item row="11" column="1">
         <widget class="QDoubleSpinBox" name="gradeStepSpinBox">
          <property name="decimals">
           <number>0</number>
          </property>
          <property name="minimum">
           <double>2.0</double>
          </property>
          <property name="maximum">
           <double>20.0</double>
          </property>
          <property name="singleStep">
           <double>1.0</double>
          </property>
          <property name="value">
           <double>5.0</double>
          </property>
          <property name="toolTip">
           <string>Amen 20-step scale: each grade is this many % of cerebellar max. Hyper +1..+4 step UP from the hyperactive threshold; hypo -1..-4 step DOWN from the hypoactive threshold. At the default 55/85 anchors and a 5% step, +4 reaches the 100% ceiling and -4 falls below 40%. (The active-render white point is set separately in the Active section.)</string>
          </property>
         </widget>
        </item>
        <item row="12" column="0">
         <widget class="QLabel" name="minRegionVoxelsLabel">
          <property name="text">
           <string>Min region voxels:</string>
          </property>
         </widget>
        </item>
        <item row="12" column="1">
         <widget class="QSpinBox" name="minRegionVoxelsSpinBox">
          <property name="minimum">
           <number>0</number>
          </property>
          <property name="maximum">
           <number>100000</number>
          </property>
          <property name="singleStep">
           <number>5</number>
          </property>
          <property name="value">
           <number>20</number>
          </property>
          <property name="toolTip">
           <string>A parcel with fewer than this many tissue voxels is too small to trust at SPECT resolution (e.g. ventral ACC ~4 voxels, nucleus accumbens ~7-9) - it is shown with its Low%/Hot% numbers but classed "Insufficient" (greyed, not auto-flagged, not counted). 0 = disable the guard. Raise it to be stricter about small subdivisions.</string>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <widget class="QCheckBox" name="colorRoiByClassCheckBox">
        <property name="text">
         <string>Tint ROI boxes by class (hypo=blue, normal=green, hyper=red)</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="regionSelectLabel">
        <property name="text">
         <string>Regions to include (tick a lobe or expand it for individual regions):</string>
        </property>
        <property name="wordWrap">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QTreeWidget" name="regionSelectTreeWidget">
        <property name="minimumHeight" stdset="0">
         <number>170</number>
        </property>
        <property name="headerHidden">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <layout class="QHBoxLayout" name="regionSelectButtonLayout">
        <item>
         <widget class="QPushButton" name="selectAllRegionsButton">
          <property name="text">
           <string>Select all</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="selectNoneRegionsButton">
          <property name="text">
           <string>Select none</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="removeUncheckedCheckBox">
          <property name="text">
           <string>Remove unchecked region ROIs</string>
          </property>
          <property name="toolTip">
           <string>When creating, also delete any region ROIs (from this taxonomy) that are NOT ticked, so the scene holds exactly your selection. Off = only add/update the ticked ones.</string>
          </property>
          <property name="checked">
           <bool>false</bool>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout" name="brainBoxLayout">
        <item>
         <widget class="QPushButton" name="createBrainBoxButton">
          <property name="text">
           <string>1. Create brain box (atlas fit)</string>
          </property>
          <property name="toolTip">
           <string>PRIMARY atlas-fit path, step 1. Drops a single Box ROI at the auto-detected brain extent. Drag its six faces to the true perfusion edges - anterior/posterior/superior/inferior in the SAGITTAL (yellow) view, left/right in the CORONAL (green) view. Enclose the whole perfused brain, cerebellum included. Confirm L/R orientation first (SPECT has no intrinsic left/right cue). The box then scales the AAL3 atlas into patient space (BSpline-refined) at the fit step.</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="showBrainBoxCheckBox">
          <property name="text">
           <string>Show box</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
          <property name="toolTip">
           <string>Show or hide the brain box in the slice and 3D views. Hiding it does not delete it - the atlas fit still uses it.</string>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <widget class="QPushButton" name="fitAtlasToBoxButton">
        <property name="text">
         <string>2. Fit atlas to brain box</string>
        </property>
        <property name="toolTip">
         <string>PRIMARY atlas-fit path, step 2. Scales the bundled template + AAL3 atlas into the brain box you drew (matching the box's 8 corners to the template brain's corners), then BSpline-refines on the SPECT to correct tilt and local shape (BRAINSFit, ~30-90 s). Fills 'Warped atlas', auto-sets the cerebellar reference, and reports a QC verdict (PASS/REVIEW/FAIL) plus the per-axis scale applied. Robust where the auto-registration fails - the box can't land in a wrong pose.</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="registerAtlasButton">
        <property name="text">
         <string>Register atlas to this SPECT (auto)</string>
        </property>
        <property name="toolTip">
         <string>One click: register this SPECT to the bundled MNI HMPAO template and warp the AAL3 atlas into patient space (BRAINSFit, ~30-90 s). Fills 'Warped atlas', auto-sets the cerebellar reference, and reports a registration-quality verdict (PASS / REVIEW / FAIL). On FAIL, use the manual workflow instead.</string>
        </property>
       </widget>
      </item>
      <item>
       <layout class="QHBoxLayout" name="landmarkLayout">
        <item>
         <widget class="QPushButton" name="placeLandmarksButton">
          <property name="text">
           <string>Place patient landmarks</string>
          </property>
          <property name="toolTip">
           <string>If the auto-registration is REVIEW/FAIL: drop 6 named landmark points, then drag each onto its TRUE location (check all 3 slice views). Five are silhouette EDGES - frontal &amp; occipital poles (front/back tips), vertex (crown), L/R temporal (outermost side of each temporal lobe). The cerebellum point is the CENTRE of the bright cerebellar blob (NOT its tip) and matters most. Confirm L/R orientation before the temporal points. Each point also carries a placement hint in its description.</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="landmarkRealignButton">
          <property name="text">
           <string>Re-align atlas from landmarks</string>
          </property>
          <property name="toolTip">
           <string>Fit a transform from your placed landmarks to the template and re-warp the AAL3 atlas onto the patient. Re-runs the QC verdict. The coarse rescue for cases the automatic registration could not align.</string>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout" name="atlasModeLayout">
        <item>
         <widget class="QLabel" name="atlasLabel">
          <property name="text">
           <string>Warped atlas:</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="qMRMLNodeComboBox" name="atlasLabelmapSelector">
          <property name="nodeTypes">
           <stringlist>
            <string>vtkMRMLLabelMapVolumeNode</string>
           </stringlist>
          </property>
          <property name="addEnabled">
           <bool>false</bool>
          </property>
          <property name="removeEnabled">
           <bool>false</bool>
          </property>
          <property name="noneEnabled">
           <bool>true</bool>
          </property>
          <property name="toolTip">
           <string>The AAL3 atlas warped into this patient's space (from the registration step). Used to seed region boxes and the cerebellar reference.</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="setReferenceFromAtlasButton">
          <property name="text">
           <string>Set reference from atlas cerebellum</string>
          </property>
          <property name="toolTip">
           <string>Read a robust cerebellar max from the warped atlas cerebellum labels into 'Manual reference'. Verify/override it - a poorly registered atlas can contaminate it.</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="seedRegionsFromAtlasButton">
          <property name="text">
           <string>Seed boxes from atlas</string>
          </property>
          <property name="toolTip">
           <string>Position each TICKED region's Box ROI at its atlas centroid (better starting points than the fixed scaffold). Regions absent from the atlas fall back to the fractional placement. Drag each box to fine-tune.</string>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout" name="atlasOverlayLayout">
        <item>
         <widget class="QCheckBox" name="showSpectCheckBox">
          <property name="text">
           <string>Show SPECT</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
          <property name="toolTip">
           <string>Show the SPECT image as the slice background. Untick to view the atlas alone.</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="showAtlasCheckBox">
          <property name="text">
           <string>Show atlas overlay</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
          <property name="toolTip">
           <string>Show the warped AAL3 atlas as a colored label overlay on the slices. Untick to view the SPECT alone.</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="atlasOpacityLabel">
          <property name="text">
           <string>Atlas opacity:</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="ctkSliderWidget" name="atlasOpacitySlider">
          <property name="decimals">
           <number>2</number>
          </property>
          <property name="singleStep">
           <double>0.05</double>
          </property>
          <property name="minimum">
           <double>0.0</double>
          </property>
          <property name="maximum">
           <double>1.0</double>
          </property>
          <property name="value">
           <double>0.5</double>
          </property>
          <property name="toolTip">
           <string>Blend of the atlas overlay over the SPECT (0 = fully transparent, 1 = fully opaque).</string>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout" name="regionButtonLayout">
        <item>
         <widget class="QPushButton" name="createRegionScaffoldButton">
          <property name="text">
           <string>Create selected region ROIs</string>
          </property>
          <property name="toolTip">
           <string>Drop one approximately-placed, named Box ROI for each TICKED region under an "Amen Regions" folder. Drag each onto the true structure before quantifying.</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="quantifyRegionsButton">
          <property name="text">
           <string>Quantify regions</string>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <widget class="QPushButton" name="quantifyFromAtlasButton">
        <property name="text">
         <string>Quantify from atlas (exact masks)</string>
        </property>
        <property name="toolTip">
         <string>Fully automatic: read each region's uptake from its PRECISE AAL3 voxels in the warped atlas - no Box ROIs needed. Set the reference first ('Set reference from atlas cerebellum'). Produces the same report + table + TSV as 'Quantify regions'.</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="exportRegionTsvButton">
        <property name="text">
         <string>Export regional table (TSV)</string>
        </property>
        <property name="toolTip">
         <string>Write regional_all.tsv and regional_hypo_hyper.tsv to the Views/export output folder.</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QTableWidget" name="regionTableWidget">
        <property name="minimumHeight" stdset="0">
         <number>220</number>
        </property>
        <property name="selectionBehavior">
         <enum>QAbstractItemView::SelectRows</enum>
        </property>
        <property name="editTriggers">
         <set>QAbstractItemView::NoEditTriggers</set>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <!-- ================= STATUS / LOG ================= -->
   <item>
    <widget class="ctkCollapsibleButton" name="statusCollapsibleButton">
     <property name="text">
      <string>Status / calibration log</string>
     </property>
     <layout class="QVBoxLayout" name="statusLayout">
      <item>
       <widget class="QPlainTextEdit" name="statusTextEdit">
        <property name="readOnly">
         <bool>true</bool>
        </property>
        <property name="minimumHeight" stdset="0">
         <number>180</number>
        </property>
       </widget>
      </item>
     </layout>
