   <!-- ================= SURFACE ================= -->
   <item>
    <widget class="ctkCollapsibleButton" name="surfaceCollapsibleButton">
     <property name="text">
      <string>Surface scan (hypoperfusion = dents / holes)</string>
     </property>
     <layout class="QVBoxLayout" name="surfaceLayout">
      <item>
       <layout class="QHBoxLayout" name="surfaceTechniqueLayout">
        <item>
